<section class="feedback-box glass" aria-labelledby="feedback-box-heading" data-feedback-box>
  <div class="feedback-box__heading">
    <div>
      <p class="eyebrow">PRIVATE MESSAGE</p>
      <h2 id="feedback-box-heading">意見を送る</h2>
    </div>
    <span class="private-badge">🔒 非公開</span>
  </div>
  <p class="feedback-box__intro">
    送った内容はサイトに公開されず、管理者だけが確認できます。アカウント登録は不要です。
  </p>
  <form data-feedback-form>
    <input class="honeypot" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
    <input type="hidden" name="category" value="other" />
    <label>
      <span>お名前 <small>任意</small></span>
      <input type="text" name="author" maxlength="40" autocomplete="nickname" placeholder="匿名のままでも送れます" />
    </label>
    <label>
      <span>ご意見</span>
      <textarea name="body" maxlength="2000" rows="9" placeholder="上のカードを選ぶと、書きやすいテンプレートが入ります。" required></textarea>
    </label>
    <div class="form-footer">
      <span class="character-count" data-character-count>0 / 2000</span>
      <button class="submit-button" type="submit" disabled>非公開で送信</button>
    </div>
    <p class="form-status" data-form-status role="status" aria-live="polite"></p>
  </form>
  <p class="feedback-box__note">個人情報、誹謗中傷、差別・脅迫、宣伝や連投は送信できません。</p>
  <p class="setup-notice" data-setup-notice hidden>意見ボックスの接続設定がまだ完了していません。</p>
</section>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_KEY =
    import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY ||
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  document.querySelectorAll<HTMLElement>("[data-feedback-box]").forEach((box) => {
    const form = box.querySelector<HTMLFormElement>("[data-feedback-form]");
    const textarea = box.querySelector<HTMLTextAreaElement>('textarea[name="body"]');
    const author = box.querySelector<HTMLInputElement>('input[name="author"]');
    const category = box.querySelector<HTMLInputElement>('input[name="category"]');
    const count = box.querySelector<HTMLElement>("[data-character-count]");
    const status = box.querySelector<HTMLElement>("[data-form-status]");
    const submit = box.querySelector<HTMLButtonElement>(".submit-button");
    const setupNotice = box.querySelector<HTMLElement>("[data-setup-notice]");
    if (!form || !textarea || !author || !category || !status || !submit) return;

    const updateCount = () => {
      if (count) count.textContent = `${textarea.value.length} / 2000`;
    };

    window.addEventListener("feedback-template-selected", ((event: CustomEvent) => {
      const { category: selectedCategory, template } = event.detail;
      category.value = selectedCategory;
      if (!textarea.value.trim() || textarea.dataset.templateApplied === "true") {
        textarea.value = template;
        textarea.dataset.templateApplied = "true";
        updateCount();
      }
      box.scrollIntoView({ behavior: "smooth", block: "center" });
      window.setTimeout(() => textarea.focus(), 420);
    }) as EventListener);

    textarea.addEventListener("input", () => {
      textarea.dataset.templateApplied = "false";
      updateCount();
    });

    if (!SUPABASE_URL || !SUPABASE_KEY) {
      setupNotice?.removeAttribute("hidden");
      return;
    }
    submit.disabled = false;
    let clientKey = localStorage.getItem("private-feedback-client-key");
    if (!clientKey) {
      clientKey = crypto.randomUUID();
      localStorage.setItem("private-feedback-client-key", clientKey);
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const honeypot = form.elements.namedItem("website") as HTMLInputElement | null;
      if (honeypot?.value) return;
      submit.disabled = true;
      status.className = "form-status";
      status.textContent = "送信中…";
      try {
        const response = await fetch(`${SUPABASE_URL}/rest/v1/rpc/submit_private_feedback`, {
          method: "POST",
          headers: {
            apikey: SUPABASE_KEY,
            Authorization: `Bearer ${SUPABASE_KEY}`,
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            p_category: category.value,
            p_author_name: author.value,
            p_body: textarea.value,
            p_client_key: clientKey,
          }),
        });
        if (!response.ok) {
          const detail = await response.json().catch(() => ({}));
          throw new Error(detail.message || "送信に失敗しました");
        }
        const submissionId = await response.json();
        if (typeof submissionId !== "string" || !submissionId) {
          throw new Error("保存結果を確認できませんでした。もう一度お試しください");
        }
        form.reset();
        category.value = "other";
        textarea.dataset.templateApplied = "false";
        updateCount();
        document.querySelectorAll("[data-feedback-template]").forEach((card) => {
          card.classList.remove("is-selected");
          card.setAttribute("aria-pressed", "false");
        });
        status.className = "form-status success";
        status.textContent = `送信しました。受付番号: ${submissionId.slice(0, 8)}`;
      } catch (error) {
        status.className = "form-status error";
        status.textContent = error instanceof Error ? error.message : "送信に失敗しました";
      } finally {
        submit.disabled = false;
      }
    });
    updateCount();
  });
</script>

<style>
  .feedback-box {
    --glass-radius: 22px;
    max-width: 760px;
    margin: 2rem auto 0;
    padding: clamp(1.2rem, 3vw, 2rem);
  }
  .feedback-box__heading, .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .eyebrow {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
  }
  h2 { margin: 0.25rem 0 0; font-size: clamp(1.3rem, 3vw, 1.7rem); }
  .private-badge {
    flex: none;
    padding: 0.42rem 0.7rem;
    border: 1px solid rgba(91, 133, 103, 0.3);
    border-radius: 999px;
    background: rgba(208, 235, 213, 0.36);
    color: #365c40;
    font-size: 0.78rem;
    font-weight: 700;
  }
  .feedback-box__intro, .feedback-box__note { color: var(--text-muted); line-height: 1.8; }
  form { display: grid; gap: 1rem; margin-top: 1.25rem; }
  label { display: grid; gap: 0.45rem; font-size: 0.9rem; font-weight: 700; }
  label small { color: var(--text-muted); font-weight: 400; }
  input, textarea {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid rgba(53, 73, 60, 0.18);
    border-radius: 13px;
    background: rgba(255, 255, 255, 0.62);
    color: inherit;
    font: inherit;
  }
  input { padding: 0.75rem 0.85rem; }
  textarea { min-height: 210px; padding: 0.9rem; line-height: 1.75; resize: vertical; }
  input:focus, textarea:focus {
    outline: 3px solid rgba(114, 164, 126, 0.2);
    border-color: rgba(75, 130, 88, 0.55);
  }
  .honeypot { position: absolute; left: -9999px; }
  .character-count { color: var(--text-muted); font-size: 0.78rem; }
  .submit-button {
    border: 0;
    border-radius: 999px;
    padding: 0.72rem 1.1rem;
    background: #456d50;
    color: white;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease;
  }
  .submit-button:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 18px rgba(49, 93, 61, 0.22);
  }
  .submit-button:disabled { cursor: wait; opacity: 0.55; }
  .form-status { min-height: 1.5em; margin: 0; font-size: 0.88rem; }
  .form-status.success { color: #2f6d3d; }
  .form-status.error { color: #a23d3d; }
  .feedback-box__note {
    margin: 1rem 0 0;
    padding-top: 1rem;
    border-top: 1px solid rgba(53, 73, 60, 0.12);
    font-size: 0.78rem;
  }
  .setup-notice { color: #8a5b20; font-size: 0.85rem; }
</style>
