  /* 写真・動画背景(ゆっくりズームするKen Burnsエフェクト付き) */
  .bg-layer {
    position: fixed;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 2.4s ease;
    z-index: -2;
    animation: kenburns 36s ease-in-out infinite alternate;
    will-change: transform, opacity;
    overflow: hidden;
  }

  .bg-layer video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #bg-b {
    animation-delay: -18s;
  }

  @keyframes kenburns {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.08);
    }
  }

  .bg-veil {
    position: fixed;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(253, 253, 252, 0.35),
      rgba(253, 253, 252, 0.58) 42%,
      rgba(253, 253, 252, 0.68)
    );
    z-index: -1;
  }

  /* ページ遷移フェード */
  #page-fade {
    position: fixed;
    inset: 0;
    background: var(--bg);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.34s ease;
    z-index: 90;
  }

  #page-fade.on {
    opacity: 1;
    pointer-events: auto;
  }

  /* スクロールで要素をふわっと表示 */
  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.9s ease,
      transform 0.9s ease;
  }

  .reveal.revealed {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-layer {
      animation: none;
    }

    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  .container {
