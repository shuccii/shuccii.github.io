    );
    opacity: 0.82;
    transition: opacity 250ms ease;
  }

  .glass:not(.glass-band):hover {
    --glass-scale: 1.012;
    border-color: rgba(255, 255, 255, 0.7);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.65) inset,
      0 18px 50px rgba(20, 30, 55, 0.19),
      0 5px 14px rgba(20, 30, 55, 0.1);
  }

  .glass:not(.glass-band):active,
  .glass.is-pressed:not(.glass-band) {
    --glass-scale: 0.975;
  }

  /* 内部の輪郭と屈折感: 縁に光が溜まる水面のようなリム */
  .glass::after {
