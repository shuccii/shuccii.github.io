  /* ========================================
     Liquid Glass共通マテリアル
     (ぼかし+彩度+明度、鏡面光、内部反射)
  ======================================== */
  .glass {
    --pointer-x: 50%;
    --pointer-y: 20%;
    --move-x: 0px;
    --move-y: 0px;
    --glass-scale: 1;
    --glass-radius: 20px;
    position: relative;
    isolation: isolate;
    background:
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.13),
        rgba(255, 255, 255, 0.018) 45%,
        rgba(255, 255, 255, 0.055)
      ),
      rgba(255, 255, 255, 0.035);
    border: 1px solid rgba(255, 255, 255, 0.44);
    border-radius: var(--glass-radius);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5) inset,
      0 -1px 0 rgba(255, 255, 255, 0.08) inset,
      0 12px 32px rgba(20, 30, 55, 0.12),
      0 3px 9px rgba(20, 30, 55, 0.06);
    /* Appleのregular glassに近い、背景を残す軽いぼかし */
    backdrop-filter: blur(11px) saturate(1.42) contrast(1.025) brightness(1.04);
    -webkit-backdrop-filter: blur(11px) saturate(1.42) contrast(1.025) brightness(1.04);
    transform: translate3d(var(--move-x), var(--move-y), 0)
      scale(var(--glass-scale));
    transition:
      transform 400ms var(--spring),
      background 300ms ease,
      border-color 300ms ease,
      box-shadow 300ms ease;
  }

  /* 背景画像の色そのものを局所的に滲ませ、透明な液体の屈折を近似する */
  .glass::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.018);
    backdrop-filter: blur(3px) saturate(1.72) contrast(1.07);
    -webkit-backdrop-filter: blur(3px) saturate(1.72) contrast(1.07);
    mask-image: radial-gradient(
      circle 190px at var(--pointer-x) var(--pointer-y),
      black 0%,
      rgba(0, 0, 0, 0.88) 38%,
      transparent 76%
    );
    -webkit-mask-image: radial-gradient(
      circle 190px at var(--pointer-x) var(--pointer-y),
      black 0%,
