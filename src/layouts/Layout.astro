  body {
    font-family:
      -apple-system, BlinkMacSystemFont, "Hiragino Sans",
      "Hiragino Kaku Gothic ProN", "Yu Gothic", Meiryo, sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 2;
    letter-spacing: 0.02em;
