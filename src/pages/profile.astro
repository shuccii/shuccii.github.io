---
import Layout from "../layouts/Layout.astro";
import site from "../data/site.json";
---

<Layout title="プロフィール | Shuichi Tani" description="谷 周一のプロフィール">
  <h1><span class="en">Profile</span>プロフィール</h1>

  <p class="lead" data-edit="profile.lead">{site.profile.lead}</p>

  <h2><span class="en">About</span>基本情報</h2>
  <dl class="profile">
    <dt>名前</dt>
    <dd data-edit="profile.name">{site.profile.name}</dd>
    <dt>所属</dt>
    <dd data-edit="profile.affiliation">{site.profile.affiliation}</dd>
    <dt>専門</dt>
    <dd data-edit="profile.specialty">{site.profile.specialty}</dd>
    <dt>経歴</dt>
    <dd data-edit="profile.background">{site.profile.background}</dd>
  </dl>

  <h2><span class="en">Message</span>研究への想い</h2>
  <p data-edit="profile.message">{site.profile.message}</p>

  <h2><span class="en">Timeline</span>あゆみ</h2>
  <ol class="timeline">
    <li data-edit="profile.timeline1">{site.profile.timeline1}</li>
    <li data-edit="profile.timeline2">{site.profile.timeline2}</li>
    <li data-edit="profile.timeline3">{site.profile.timeline3}</li>
  </ol>

  <h2><span class="en">Skills</span>スキル</h2>
  <dl class="skills">
    <dt>機械学習</dt>
    <dd data-edit="profile.skillsML">{site.profile.skillsML}</dd>
    <dt>Python・データ解析</dt>
    <dd data-edit="profile.skillsPython">{site.profile.skillsPython}</dd>
    <dt>ツール</dt>
    <dd data-edit="profile.skillsTools">{site.profile.skillsTools}</dd>
  </dl>

  <h2><span class="en">Research</span>研究テーマ</h2>
  <p>
    機械学習を用いた核融合炉材料の物性予測(Materials Informatics)。
    詳しくは<a href="/research/">研究ページ</a>へ。
  </p>

  <h2><span class="en">Interests</span>関心事・趣味</h2>
  <p data-edit="profile.interests">{site.profile.interests}</p>

  <h2><span class="en">Qualifications</span>資格・受賞歴</h2>
  <p data-edit="profile.qualifications">{site.profile.qualifications}</p>

  <h2><span class="en">Links</span>リンク</h2>
  <ul>
    <li>
      <a
        href="https://github.com/shuccii"
        target="_blank"
        rel="noopener noreferrer">GitHub: shuccii ↗</a
      >
    </li>
    <li><a href="/research/">研究内容 →</a></li>
    <li><a href="/blog/">ブログ →</a></li>
  </ul>
  <p class="sns-note">
    SNSのリンクは、編集モードでページ最下部のパネルにURLを入力すると
    フッターにアイコンとして表示されます。
  </p>
</Layout>

<style>
  .lead {
    font-size: 1.05rem;
    max-width: 36em;
    margin-bottom: 2.5rem;
  }

  .profile,
  .skills {
    display: grid;
    grid-template-columns: 10em 1fr;
    row-gap: 0.9rem;
    column-gap: 1.5rem;
    padding: 0;
    color: inherit;
  }

  .profile {
    grid-template-columns: 6em 1fr;
  }

  .profile dt,
  .skills dt {
    color: var(--text-muted);
    font-size: 0.9rem;
    letter-spacing: 0.1em;
  }

  .profile dd,
  .skills dd {
    margin: 0;
  }

  /* あゆみ */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline li {
    position: relative;
    padding: 0 0 1.4rem 1.9rem;
  }

  .timeline li::before {
    content: "";
    position: absolute;
    left: 0.42rem;
    top: 0.65rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
  }

  .timeline li:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 0.65rem;
    top: 1.3rem;
    bottom: -0.3rem;
    width: 1px;
    background: var(--border);
  }

  .sns-note {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  @media (max-width: 520px) {
    .profile,
    .skills {
      grid-template-columns: 1fr;
      row-gap: 0.15rem;
    }

    .profile dd,
    .skills dd {
      margin-bottom: 0.9rem;
    }
  }
</style>
