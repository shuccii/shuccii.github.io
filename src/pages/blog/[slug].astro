---
import Layout from "../../layouts/Layout.astro";
import CommentSection from "../../components/CommentSection.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import { getPhotos, getVideos } from "../../lib/media";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const d = post.data.date;
const fmt = `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, "0")}/${String(d.getDate()).padStart(2, "0")}`;

// frontmatter で指定された写真・ビデオを assets から引き当てる
const allPhotos = getPhotos();
const allVideos = getVideos();
const postPhotos = post.data.photos
  .map((file) => allPhotos.find((p) => p.file === file))
  .filter((p) => p !== undefined);
const postVideos = post.data.videos
  .map((file) => allVideos.find((v) => v.file === file))
  .filter((v) => v !== undefined);
---

<Layout title={`${post.data.title} | Shuichi Tani`} description={post.data.description}>
  <article>
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <p class="meta">
        <time>{fmt}</time>
        {
          post.data.tags.map((tag) => (
            <a class="tag" href={`/search/?q=${encodeURIComponent(tag)}`}>
              {tag}
            </a>
          ))
        }
      </p>
    </header>

    <div class="post-body">
      <Content />
    </div>

    {
      postPhotos.length > 0 && (
        <section class="post-media">
          <h2>
            <span class="en">Photos</span>この記事の写真
          </h2>
          <div class="media-grid">
            {postPhotos.map((photo) => (
              <figure class="glass">
                <button
                  class="post-photo-zoom"
                  type="button"
                  data-full={photo.url}
                  data-alt={photo.name}
                  aria-label={`写真「${photo.name}」を拡大表示`}
                >
                  <Image src={photo.image} alt={photo.name} width={640} loading="lazy" />
                </button>
                <figcaption>{photo.name}</figcaption>
              </figure>
            ))}
          </div>
        </section>
      )
    }

    {
      postVideos.length > 0 && (
        <section class="post-media">
          <h2>
            <span class="en">Videos</span>この記事のビデオ
          </h2>
          <div class="video-grid">
            {postVideos.map((video) => (
              <figure class="glass">
                <video src={video.url} controls preload="metadata" />
                <figcaption>{video.name}</figcaption>
              </figure>
            ))}
          </div>
        </section>
      )
    }
  </article>

  <dialog id="post-lightbox" aria-label="記事内写真の拡大表示">
    <button id="post-lightbox-close" type="button" aria-label="閉じる">×</button>
    <img id="post-lightbox-image" alt="" />
  </dialog>

  <CommentSection />

  <p class="back"><a href="/blog/">← 記事一覧に戻る</a></p>
</Layout>

<script>
  const lightbox = document.querySelector<HTMLDialogElement>("#post-lightbox");
  const lightboxImage =
    document.querySelector<HTMLImageElement>("#post-lightbox-image");
  const closeButton =
    document.querySelector<HTMLButtonElement>("#post-lightbox-close");

  const openLightbox = (src: string, alt: string) => {
    if (!lightbox || !lightboxImage || !src) return;
    lightboxImage.src = src;
    lightboxImage.alt = alt;
    lightbox.showModal();
  };

  document
    .querySelectorAll<HTMLButtonElement>(".post-photo-zoom")
    .forEach((button) => {
      button.addEventListener("click", () => {
        openLightbox(button.dataset.full ?? "", button.dataset.alt ?? "");
      });
    });

  // Markdown本文に直接置かれた画像にも同じ拡大操作を付ける。
  document.querySelectorAll<HTMLImageElement>(".post-body img").forEach((image) => {
    image.classList.add("post-body-zoom");
    image.tabIndex = 0;
    image.setAttribute("role", "button");
    image.setAttribute(
      "aria-label",
      `${image.alt ? `写真「${image.alt}」` : "写真"}を拡大表示`,
    );

    const open = () => openLightbox(image.currentSrc || image.src, image.alt);
    image.addEventListener("click", open);
    image.addEventListener("keydown", (event) => {
      if (event.key !== "Enter" && event.key !== " ") return;
      event.preventDefault();
      open();
    });
  });

  closeButton?.addEventListener("click", () => lightbox?.close());
  lightbox?.addEventListener("click", (event) => {
    if (event.target === lightbox) lightbox.close();
  });
</script>

<style>
  .post-header h1 {
    margin-bottom: 0.5rem;
  }

  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.75rem;
  }

  .post-media h2 {
    margin-top: 3rem;
  }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .media-grid figure {
    --glass-radius: 14px;
    margin: 0;
    overflow: hidden;
  }

  .post-photo-zoom {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
  }

  .post-photo-zoom :global(img) {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 13px 13px 0 0;
    border: 0;
    transition: opacity 0.25s ease;
  }

  .post-photo-zoom:hover :global(img) {
    opacity: 0.85;
  }

  .video-grid {
    display: grid;
    gap: 1.5rem;
  }

  .video-grid figure {
    --glass-radius: 14px;
    margin: 0;
    overflow: hidden;
  }

  .video-grid video {
    width: 100%;
    border-radius: 13px 13px 0 0;
    border: 0;
    background: #000;
  }

  figcaption {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
    padding: 0.55rem 0.7rem 0.65rem;
  }

  .back {
    margin-top: 3.5rem;
  }

  #post-lightbox {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    max-width: none;
    max-height: none;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    overflow: hidden;
    align-items: center;
    justify-content: center;
  }

  #post-lightbox[open] {
    display: flex;
  }

  #post-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.82);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  #post-lightbox-image {
    display: block;
    width: auto;
    height: auto;
    max-width: min(92vw, 1200px);
    max-height: 88vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.42);
  }

  #post-lightbox-close {
    position: fixed;
    top: 1rem;
    top: calc(1rem + env(safe-area-inset-top, 0px));
    right: 1rem;
    right: calc(1rem + env(safe-area-inset-right, 0px));
    z-index: 1;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid rgba(255, 255, 255, 0.38);
    border-radius: 50%;
    color: #fff;
    background: rgba(0, 0, 0, 0.62);
    font-size: 1.9rem;
    line-height: 1;
    cursor: pointer;
  }
</style>

<style is:global>
  .post-body img,
  .post-body video {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }

  .post-body img.post-body-zoom {
    cursor: zoom-in;
  }

  .post-body img.post-body-zoom:hover {
    opacity: 0.88;
  }

  @media (max-width: 520px) {
    .post-header h1 {
      font-size: 1.35rem;
      line-height: 1.55;
      margin-bottom: 0.35rem;
    }

    .meta {
      gap: 0.4rem;
      padding-bottom: 1rem;
      margin-bottom: 1.25rem;
    }

    .media-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .post-photo-zoom img {
      height: 128px;
    }

    .post-media h2 {
      margin-top: 2.25rem;
    }

    #post-lightbox-image {
      max-width: 94vw;
      max-height: 80vh;
    }
  }
</style>
