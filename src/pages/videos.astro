---
import Layout from "../layouts/Layout.astro";
import { getVideos, getMediaPostMap } from "../lib/media";

const videos = getVideos();
const postMap = await getMediaPostMap();

// YouTube の動画を載せる場合は、ここに ID とタイトルを追加する
// 例: { id: "dQw4w9WgXcQ", title: "動画のタイトル" }
const youtubeVideos: { id: string; title: string }[] = [];
---

<Layout title="ビデオ | Shuichi Tani">
  <h1><span class="en">Video</span>ビデオ</h1>
  {
    videos.length === 0 && youtubeVideos.length === 0 ? (
      <div class="empty">
        <p>まだビデオがありません。追加する方法は2つあります。</p>
        <ul>
          <li>
            動画ファイル(mp4 など)を <code>src/assets/videos/</code>
            に入れる(ファイル名がタイトルになります)
          </li>
          <li>
            YouTube の動画は <code>src/pages/videos.astro</code> 内の
            <code>youtubeVideos</code> に ID とタイトルを追加する
          </li>
        </ul>
      </div>
    ) : (
      <div class="video-list">
        {videos.map((video) => {
          const refs = postMap.get(video.file) ?? [];
          const post = refs[0];
          return (
            <figure>
              <video src={video.url} controls preload="metadata" />
              <figcaption>
                {video.name}
                {post && (
                  <a class="post-link" href={`/blog/${post.slug}/`}>
                    📝 {post.title}
                  </a>
                )}
              </figcaption>
            </figure>
          );
        })}
        {youtubeVideos.map(({ id, title }) => (
          <figure>
            <div class="yt-wrap">
              <iframe
                src={`https://www.youtube-nocookie.com/embed/${id}`}
                title={title}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            </div>
            <figcaption>{title}</figcaption>
          </figure>
        ))}
      </div>
    )
  }
</Layout>

<style>
  .video-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  figure {
    margin: 0;
  }

  video {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: #000;
  }

  .yt-wrap {
    position: relative;
    height: 180px;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .yt-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  figcaption {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-top: 0.4rem;
  }

  .post-link {
    display: block;
    font-size: 0.82rem;
    margin-top: 0.1rem;
  }

  .empty {
    color: var(--text-muted);
    background: var(--panel);
    border: 1px dashed var(--border);
    border-radius: 4px;
    padding: 1.5rem;
  }

  .empty ul {
    margin-bottom: 0;
  }
</style>
