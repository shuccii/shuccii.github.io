---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { getTileMedia, getPhotos } from "../lib/media";
import site from "../data/site.json";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const recentPosts = posts.slice(0, 8);
const recentPhotos = getPhotos().slice(0, 4);

const fmt = (d: Date) =>
  `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, "0")}/${String(d.getDate()).padStart(2, "0")}`;

// 各ページへのセクションブロック(写真・動画を順に割り当て)
const tileMedia = getTileMedia();
const blocks = [
  { href: "/blog/", en: "Blog", ja: "ブログ", desc: site.home.secBlog },
  { href: "/photos/", en: "Photo", ja: "写真", desc: site.home.secPhoto },
  { href: "/videos/", en: "Video", ja: "ビデオ", desc: site.home.secVideo },
  { href: "/music/", en: "Music", ja: "音楽", desc: site.home.secMusic },
  { href: "/profile/", en: "Profile", ja: "プロフィール", desc: site.home.secProfile },
  { href: "/research/", en: "Research", ja: "研究", desc: site.home.secResearch },
].map((block, i) => ({
  ...block,
  media: tileMedia.length > 0 ? tileMedia[i % tileMedia.length] : null,
}));
---

<Layout title="余白の庭 | Shuichi Tani" wide>
  <section class="hero">
    <p class="hero-en" data-edit="home.titleEn">{site.home.titleEn}</p>
    <h1 class="hero-title" data-edit="home.title">{site.home.title}</h1>
    <p class="hero-byline" data-edit="home.byline">{site.home.byline}</p>

    <div class="manifesto">
      <p class="m-line" data-edit="home.manifesto1">{site.home.manifesto1}</p>
      <p class="m-line" data-edit="home.manifesto2">{site.home.manifesto2}</p>
      <p class="m-line" data-edit="home.manifesto3">{site.home.manifesto3}</p>
      <p class="m-line" data-edit="home.manifesto4">{site.home.manifesto4}</p>
    </div>

    <p class="hero-lead" data-edit="home.lead">{site.home.lead}</p>
    <p class="scroll-cue" aria-hidden="true">SCROLL<span></span></p>
  </section>

  <section class="blocks">
    {
      blocks.map((block) => (
        <a
          class="block"
          href={block.href}
          data-glass-area
        >
          <span class="block-ghost" aria-hidden="true">{block.en}</span>
          <span class="block-media" aria-hidden="true">
            {
              block.media?.type === "image" ? (
                <span
                  class="block-bg"
                  style={`background-image: url("${block.media.url}")`}
                />
              ) : block.media?.type === "video" ? (
                <video class="block-video" autoplay muted loop playsinline preload="metadata">
                  <source src={block.media.url} />
                </video>
              ) : null
            }
          </span>
          <span class="block-text glass">
            <span class="block-en">{block.en}</span>
            <span class="block-ja">{block.ja}</span>
            <span class="block-desc" data-edit={`home.sec${block.en}`}>
              {block.desc}
            </span>
            <span class="block-more">View more →</span>
          </span>
        </a>
      ))
    }
  </section>

  <div class="section-head">
    <span class="section-ghost" aria-hidden="true">Updates</span>
    <h2 class="section-title">最近の更新</h2>
  </div>
  <p class="updates-hint">→ 横にスクロールできます</p>
  <div class="updates-strip">
    {
      recentPosts.map((post) => (
        <a class="update-card glass" href={`/blog/${post.id}/`}>
          <span class="update-type">BLOG</span>
          <span class="update-date">{fmt(post.data.date)}</span>
          <span class="update-title">{post.data.title}</span>
          {post.data.description && (
            <span class="update-desc">{post.data.description}</span>
          )}
        </a>
      ))
    }
    {
      recentPhotos.map((photo) => (
        <a class="update-card photo-card glass" href="/photos/">
          <Image src={photo.image} alt={photo.name} width={480} loading="lazy" />
          <span class="update-type">PHOTO</span>
          <span class="update-title">{photo.name}</span>
        </a>
      ))
    }
    {
      recentPosts.length === 0 && recentPhotos.length === 0 && (
        <p>まだ更新がありません。</p>
      )
    }
  </div>
</Layout>

<style>
  .hero {
    min-height: 62vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2.5rem 0 3.5rem;
    position: relative;
  }

  .hero-en {
    font-size: 0.75rem;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.6rem;
    animation: heroIn 1s ease both;
  }

  .hero-title {
    font-size: clamp(2.6rem, 4.5vw, 3.4rem);
    letter-spacing: 0.26em;
    margin-bottom: 0.6rem;
    animation: heroIn 1s ease both;
  }

  .hero-byline {
    font-size: 0.82rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin-bottom: 2.1rem;
    animation: heroIn 1s ease 0.15s both;
  }

  @keyframes heroIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* 余白の庭: 意味を語る4行(1行ずつ順にふわっと現れる) */
  .manifesto {
    max-width: 36em;
    border-left: 1px solid var(--border);
    padding-left: 1.3rem;
    margin-bottom: 2rem;
  }

  .m-line {
    font-size: 0.95rem;
    line-height: 2.1;
    color: var(--text);
    margin-bottom: 0.15rem;
    opacity: 0;
    transform: translateY(12px);
    animation: mLineIn 0.9s ease forwards;
  }

  .m-line:nth-child(1) {
    animation-delay: 0.35s;
  }
  .m-line:nth-child(2) {
    animation-delay: 0.65s;
  }
  .m-line:nth-child(3) {
    animation-delay: 0.95s;
  }
  .m-line:nth-child(4) {
    animation-delay: 1.25s;
  }

  @keyframes mLineIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title,
    .hero-en,
    .hero-byline,
    .m-line {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  .hero-lead {
    max-width: 36em;
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  .scroll-cue {
    position: absolute;
    bottom: 0;
    left: 0;
    font-size: 0.62rem;
    letter-spacing: 0.35em;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .scroll-cue span {
    display: inline-block;
    width: 56px;
    height: 1px;
    background: var(--text-muted);
    position: relative;
    overflow: hidden;
  }

  .scroll-cue span::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--accent);
    animation: cue 2.2s ease-in-out infinite;
  }

  @keyframes cue {
    0% {
      transform: translateX(-100%);
    }
    60%,
    100% {
      transform: translateX(100%);
    }
  }

  /* 巨大なアウトライン欧文(セクション見出しの背景装飾) */
  .block-ghost,
  .section-ghost {
    display: block;
    font-family: "Times New Roman", "Hiragino Mincho ProN", Georgia, serif;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: transparent;
    /* 写真の上でもクッキリ読めるよう、白のストロークに淡い影を添える */
    -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.92);
    filter: drop-shadow(0 1px 2px rgba(30, 40, 55, 0.4))
      drop-shadow(0 6px 18px rgba(30, 40, 55, 0.22));
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  /* セクションブロック: 大きな写真 + ガラス質のテキストカードを交互に */
  .blocks {
    display: flex;
    flex-direction: column;
    gap: clamp(5rem, 10vw, 9rem);
    margin: clamp(4rem, 8vw, 7rem) 0 clamp(5rem, 9vw, 8rem);
  }

  .block {
    position: relative;
    display: flex;
    align-items: flex-end;
    color: inherit;
    text-decoration: none;
  }

  .block:hover {
    text-decoration: none;
  }

  .block:nth-child(even) {
    flex-direction: row-reverse;
  }

  .block-ghost {
    position: absolute;
    top: calc(clamp(3.2rem, 8vw, 6.8rem) * -0.52);
    font-size: clamp(3.2rem, 8vw, 6.8rem);
    z-index: 2;
  }

  .block:nth-child(odd) .block-ghost {
    left: -0.03em;
  }

  .block:nth-child(even) .block-ghost {
    right: -0.03em;
  }

  .block-media {
    position: relative;
    display: block;
    width: 62%;
    aspect-ratio: 3 / 2;
    border-radius: 18px;
    overflow: hidden;
    background: #b9c2cb;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.25),
      0 24px 60px rgba(25, 35, 50, 0.16);
  }

  .block-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 1.1s cubic-bezier(0.2, 0.6, 0.2, 1);
  }

  .block-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.1s cubic-bezier(0.2, 0.6, 0.2, 1);
  }

  .block:hover .block-bg,
  .block:hover .block-video {
    transform: scale(1.05);
  }

  /* クリック時: 写真がぐっとズームして白フェードで遷移 */
  .block.leaving .block-bg,
  .block.leaving .block-video {
    transform: scale(1.12);
    transition: transform 0.5s ease;
  }

  .block-text {
    --glass-radius: 20px;
    z-index: 1;
    display: flex;
    flex-direction: column;
    width: 44%;
    margin-bottom: clamp(1.5rem, 3.5vw, 3rem);
    padding: clamp(1.5rem, 3vw, 2.4rem) clamp(1.5rem, 3vw, 2.6rem);
    color: #2c343d;
  }

  .block:nth-child(odd) .block-text {
    margin-left: -6%;
  }

  .block:nth-child(even) .block-text {
    margin-right: -6%;
  }

  .block-en {
    font-size: 0.66rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: #1e5aa8;
  }

  .block-ja {
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    margin: 0.3rem 0 0.55rem;
  }

  .block-desc {
    font-size: 0.86rem;
    line-height: 1.95;
    color: #4b545e;
  }

  .block-more {
    margin-top: 1rem;
    font-size: 0.7rem;
    letter-spacing: 0.24em;
    color: #6b7684;
    transition:
      color 0.3s ease,
      transform 0.3s ease;
  }

  .block:hover .block-more {
    color: #1e5aa8;
    transform: translateX(6px);
  }

  .block:hover .block-text {
    --glass-scale: 1.012;
    border-color: rgba(255, 255, 255, 0.7);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.65) inset,
      0 18px 50px rgba(20, 30, 55, 0.19),
      0 5px 14px rgba(20, 30, 55, 0.1);
  }

  /* 最近の更新 */
  .section-head {
    position: relative;
    padding-top: clamp(4rem, 7vw, 6rem);
    margin-bottom: 0.75rem;
  }

  .section-ghost {
    position: absolute;
    top: 0.4rem;
    left: -0.03em;
    font-size: clamp(2.8rem, 7vw, 5.6rem);
    z-index: 0;
  }

  .section-title {
    position: relative;
    z-index: 1;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    margin: 0;
    line-height: 1.5;
  }

  .updates-hint {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 0.8rem;
  }

  .updates-strip {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding: 0.25rem 0.25rem 1.25rem;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  .updates-strip::-webkit-scrollbar {
    height: 6px;
  }

  .updates-strip::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 3px;
  }

  .update-card {
    --glass-radius: 16px;
    flex: 0 0 240px;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    padding: 1.1rem 1.2rem;
    color: #30343a;
  }

  .update-card:hover {
    text-decoration: none;
  }

  .update-type {
    font-size: 0.62rem;
    letter-spacing: 0.3em;
    color: #1e5aa8;
  }

  .update-date {
    font-size: 0.78rem;
    color: #68717a;
    margin-top: 0.2rem;
  }

  .update-title {
    font-weight: 600;
    line-height: 1.7;
    margin-top: 0.3rem;
  }

  .update-desc {
    font-size: 0.82rem;
    color: #59616b;
    line-height: 1.7;
    margin-top: 0.3rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .photo-card {
    padding: 0;
    overflow: hidden;
  }

  .photo-card :global(img) {
    width: 100%;
    height: 130px;
    object-fit: cover;
  }

  .photo-card .update-type {
    margin: 0.7rem 1.2rem 0;
  }

  .photo-card .update-title {
    margin: 0.1rem 1.2rem 0.9rem;
    font-size: 0.88rem;
  }

  /* タブレット: 重なりを浅くする */
  @media (max-width: 900px) {
    .block-media {
      width: 58%;
    }

    .block-text {
      width: 48%;
    }
  }

  /* スマホ(iPhoneの縦長画面): 1画面に収まる縦積みレイアウト */
  @media (max-width: 768px) {
    .hero {
      min-height: calc(100vh - 4.25rem);
      min-height: calc(100svh - 4.25rem);
      padding: 1.8rem 0 2.5rem;
      justify-content: flex-start;
    }

    .hero-en {
      font-size: 0.66rem;
      letter-spacing: 0.32em;
      margin-bottom: 0.5rem;
    }

    .hero-title {
      font-size: clamp(1.9rem, 9vw, 2.25rem);
      letter-spacing: 0.14em;
      margin-bottom: 1.35rem;
      text-shadow: 0 1px 12px rgba(255, 255, 255, 0.58);
    }

    .manifesto {
      max-width: none;
      margin-bottom: 1rem;
      padding: 1rem 1rem 1.05rem;
      border: 1px solid rgba(255, 255, 255, 0.54);
      border-radius: 16px;
      background: rgba(247, 249, 251, 0.62);
      box-shadow: 0 10px 30px rgba(28, 38, 55, 0.1);
      backdrop-filter: blur(10px) saturate(1.2);
      -webkit-backdrop-filter: blur(10px) saturate(1.2);
    }

    .m-line {
      font-size: 0.86rem;
      line-height: 1.85;
      margin-bottom: 0.35rem;
    }

    .m-line:last-child {
      margin-bottom: 0;
    }

    .hero-lead {
      max-width: none;
      padding: 0 0.15rem;
      font-size: 0.8rem;
      line-height: 1.8;
      color: color-mix(in srgb, var(--text) 78%, transparent);
      text-shadow: 0 1px 8px rgba(255, 255, 255, 0.75);
    }

    .scroll-cue {
      display: none;
    }

    .blocks {
      gap: 4rem;
      margin: 3.25rem 0 4rem;
    }

    .block,
    .block:nth-child(even) {
      flex-direction: column;
      align-items: stretch;
    }

    .block-ghost {
      position: absolute;
      top: calc(clamp(2.6rem, 13vw, 3.6rem) * -0.55);
      font-size: clamp(2.6rem, 13vw, 3.6rem);
    }

    .block:nth-child(even) .block-ghost {
      right: auto;
      left: -0.03em;
    }

    .block-media {
      width: 100%;
      aspect-ratio: 4 / 3;
      border-radius: 15px;
    }

    .block-text,
    .block:nth-child(odd) .block-text,
    .block:nth-child(even) .block-text {
      width: auto;
      margin: -1.15rem 0.55rem 0;
      padding: 1.15rem 1.1rem 1.25rem;
      border-radius: 16px;
    }

    .block-ja {
      font-size: 1.2rem;
    }

    .block-desc {
      font-size: 0.81rem;
      line-height: 1.75;
    }

    .block-more {
      margin-top: 0.75rem;
    }

    .updates-strip {
      gap: 0.75rem;
      margin: 0 -1rem;
      padding: 0.3rem 1rem 1.15rem;
      scroll-padding-inline: 1rem;
    }

    .update-card {
      flex-basis: min(82vw, 300px);
      padding: 0.95rem 1rem;
    }

    .section-head {
      padding-top: 3.5rem;
    }

    .section-ghost {
      font-size: clamp(2.7rem, 15vw, 3.8rem);
    }

    .photo-card .update-type {
      margin: 0.6rem 1rem 0;
    }

    .photo-card .update-title {
      margin-right: 1rem;
      margin-left: 1rem;
    }
  }
</style>
