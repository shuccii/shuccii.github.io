---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { getPhotos, getMediaPostMap } from "../lib/media";

const photos = getPhotos();
const postMap = await getMediaPostMap();
---

<Layout title="写真 | Shuichi Tani">
  <h1><span class="en">Photo</span>写真</h1>
  <p class="hint">
    ここに追加した写真は、サイト全体の背景としてもランダムに表示されます。
    写真をクリックすると、縦横比を保ったまま拡大表示されます。
  </p>
  {
    photos.length > 0 ? (
          <div class="gallery">
        {photos.map((photo) => {
          const refs = postMap.get(photo.file) ?? [];
          const post = refs[0];
          return (
            <figure>
              <button
                class="photo-zoom"
                type="button"
                data-full={photo.url}
                data-alt={photo.name}
                aria-label={`写真「${photo.name}」を拡大表示`}
              >
                <Image src={photo.image} alt={photo.name} width={640} loading="lazy" />
              </button>
              <figcaption>
                {photo.name}
                {post && (
                  <a class="post-link" href={`/blog/${post.slug}/`}>
                    📝 {post.title}
                  </a>
                )}
              </figcaption>
            </figure>
          );
        })}
      </div>
    ) : (
      <div class="empty">
        <p>まだ写真がありません。</p>
        <p>
          <code>src/assets/photos/</code> に画像ファイル(jpg / png / webp
          など)を入れると、このページと背景に自動的に反映されます。
          ファイル名がキャプションになります(例:
          <code>2026-07-14_研究室の風景.jpg</code>)。
        </p>
      </div>
    )
  }
  <dialog id="photo-lightbox" aria-label="写真の拡大表示">
    <button id="photo-lightbox-close" type="button" aria-label="閉じる">×</button>
    <img id="photo-lightbox-image" alt="" />
  </dialog>
</Layout>

<script>
  const lightbox = document.querySelector<HTMLDialogElement>("#photo-lightbox");
  const lightboxImage = document.querySelector<HTMLImageElement>("#photo-lightbox-image");
  const closeButton = document.querySelector<HTMLButtonElement>("#photo-lightbox-close");

  document.querySelectorAll<HTMLButtonElement>(".photo-zoom").forEach((button) => {
    button.addEventListener("click", () => {
      if (!lightbox || !lightboxImage) return;
      lightboxImage.src = button.dataset.full ?? "";
      lightboxImage.alt = button.dataset.alt ?? "";
      lightbox.showModal();
    });
  });

  closeButton?.addEventListener("click", () => lightbox?.close());
  lightbox?.addEventListener("click", (event) => {
    if (event.target === lightbox) lightbox.close();
  });
</script>

<style>
  .hint {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1.75rem;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  figure {
    margin: 0;
  }

  .photo-zoom {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
  }

  .photo-zoom :global(img) {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--border);
    transition: opacity 0.25s ease;
  }

  .photo-zoom:hover :global(img) {
    opacity: 0.85;
  }

  figcaption {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-top: 0.35rem;
    line-height: 1.6;
  }

  .post-link {
    display: block;
    font-size: 0.8rem;
    margin-top: 0.1rem;
  }

  .empty {
    color: var(--text-muted);
    background: var(--panel);
    border: 1px dashed var(--border);
    border-radius: 4px;
    padding: 1.5rem;
  }

  .empty p:last-child {
    margin-bottom: 0;
  }

  #photo-lightbox {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    max-width: none;
    max-height: none;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    overflow: hidden;
    align-items: center;
    justify-content: center;
  }

  #photo-lightbox[open] {
    display: flex;
  }

  #photo-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.78);
  }

  #photo-lightbox-image {
    display: block;
    width: auto;
    height: auto;
    max-width: min(90vw, 960px);
    max-height: 84vh;
    object-fit: contain;
    border-radius: 4px;
  }

  #photo-lightbox-close {
    position: fixed;
    top: 1rem;
    right: 1rem;
    width: 2.5rem;
    height: 2.5rem;
    border: 0;
    border-radius: 50%;
    color: #fff;
    background: rgba(0, 0, 0, 0.58);
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
  }
</style>
